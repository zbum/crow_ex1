{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "description": "Default build using Unix Makefiles",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_BENCHMARKS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug Config",
            "description": "Debug build with all symbols",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_BENCHMARKS": "OFF"
            }
        },
        {
            "name": "release",
            "displayName": "Release Config",
            "description": "Release build with optimizations",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "BUILD_BENCHMARKS": "ON"
            }
        },
        {
            "name": "ninja",
            "displayName": "Ninja Config",
            "description": "Build using Ninja generator",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_BENCHMARKS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "displayName": "Default Build",
            "description": "Build with default configuration"
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "displayName": "Debug Build",
            "description": "Build debug version"
        },
        {
            "name": "release",
            "configurePreset": "release",
            "displayName": "Release Build",
            "description": "Build release version"
        },
        {
            "name": "ninja",
            "configurePreset": "ninja",
            "displayName": "Ninja Build",
            "description": "Build using Ninja"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "displayName": "Default Tests",
            "description": "Run all tests"
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "displayName": "Debug Tests",
            "description": "Run debug tests"
        }
    ]
}
